{
    "name": "bambamboole/filament-pages",
    "description": "A Filament pages plugin",
    "keywords": [
        "bambamboole",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-pages"
    ],
    "homepage": "https://github.com/bambamboole/filament-pages",
    "support": {
        "issues": "https://github.com/bambamboole/filament-pages/issues",
        "source": "https://github.com/bambamboole/filament-pages"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Manuel Bambamboole",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-livewire": "^3.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "Bambamboole\\FilamentPages\\": "src/",
            "Bambamboole\\FilamentPages\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bambamboole\\FilamentPages\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@php ./vendor/bin/testbench package:discover --ansi"
        ],
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run",
        "clear": [
            "rm -rf vendor/orchestra/testbench-core/laravel/database/migrations",
            "rm -rf vendor/orchestra/testbench-core/laravel/database/database.sqlite",
            "@php vendor/bin/testbench package:purge-skeleton --ansi"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bambamboole\\FilamentPages\\FilamentPagesServiceProvider"
            ],
            "aliases": {
                "FilamentPages": "Bambamboole\\FilamentPages\\Facades\\FilamentPages"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
